#include "studio36kb-layouts.dtsi"
#include <dt-bindings/zmk/matrix_transform.h>

/ {
    matrix_transform0: matrix_transform0 {
        compatible = "zmk,matrix-transform";
        columns = <10>;
        rows = <6>;
        map = <
            RC(0,4) RC(0,0) RC(0,1) RC(0,2) RC(0,3) RC(0,9) RC(0,5) RC(0,6) RC(0,7) RC(0,8)
            RC(1,4) RC(1,0) RC(1,1) RC(1,2) RC(1,3) RC(1,9) RC(1,5) RC(1,6) RC(1,7) RC(1,8)
            RC(2,4) RC(2,0) RC(2,1) RC(2,2) RC(2,3) RC(2,9) RC(2,5) RC(2,6) RC(2,7) RC(2,8)
            RC(3,0) RC(3,1) RC(3,2) RC(3,3) RC(3,5) RC(3,6) RC(3,7) RC(3,8)
            RC(4,0) RC(4,1) RC(4,2) RC(4,3) RC(4,5) RC(4,6) RC(4,7) RC(4,8)
            RC(5,0) RC(5,1) RC(5,2) RC(5,3) RC(5,5) RC(5,6) RC(5,7) RC(5,8)
        >;
    };
};

&physical_layout_studio36kb {
    transform = <&matrix_transform0>;
};

// Encoders for all parts of the keyboard.
// If the encoder(s) are not behaving as expected,
// update steps and triggers-per-rotation to match your hardware.
// All pin assignments are done in the part overlays.

/ {
    encoder_left0: encoder_left0 {
        compatible = "alps,ec11";
        steps = <80>;
        status = "disabled";
    };
    encoder_left1: encoder_left1 {
        compatible = "alps,ec11";
        steps = <80>;
        status = "disabled";
    };
    encoder_right0: encoder_right0 {
        compatible = "alps,ec11";
        steps = <80>;
        status = "disabled";
    };
    encoder_right1: encoder_right1 {
        compatible = "alps,ec11";
        steps = <80>;
        status = "disabled";
    };

    sensors: sensors {
        compatible = "zmk,keymap-sensors";
        sensors = <&encoder_left0 &encoder_left1 &encoder_right0 &encoder_right1>;
        triggers-per-rotation = <20>;
    };
};

