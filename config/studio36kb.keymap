#define ZMK_POINTING_DEFAULT_MOVE_VAL 2000  // default: 600
#define ZMK_POINTING_DEFAULT_SCRL_VAL 20    // default: 10

#include <behaviors.dtsi>
#include <dt-bindings/zmk/bt.h>
#include <dt-bindings/zmk/keys.h>

/ {
    combos {
        compatible = "zmk,combos";

        Delete {
            bindings = <&lt 7 DELETE>;
            key-positions = <3 4>;
            layers = <0>;
        };

        AllTabs {
            bindings = <&WinTab>;
            key-positions = <11 12 13>;
        };

        SwitchWindows {
            bindings = <&kp LA(TAB)>;
            key-positions = <24 23>;
        };

        SwitchInternal {
            bindings = <&kp LC(LA(TAB))>;
            key-positions = <24 22>;
        };

        Undo {
            bindings = <&kp LC(Z)>;
            key-positions = <20 21>;
        };

        Save {
            bindings = <&kp LC(S)>;
            key-positions = <0 1>;
        };

        FileExplorer {
            bindings = <&kp LG(E)>;
            key-positions = <2 14>;
        };

        capsLock {
            bindings = <&kp CAPSLOCK>;
            key-positions = <1 2>;
        };

        Search {
            bindings = <&kp LC(E)>;
            key-positions = <3 2>;
        };

        Redo {
            bindings = <&kp LC(Y)>;
            key-positions = <10 11>;
        };

        Delete2 {
            bindings = <&kp DELETE>;
            key-positions = <5 15>;
        };

        Windows {
            bindings = <&kp LEFT_WIN>;
            key-positions = <25 15>;
        };
    };

    macros {
        Bluetooth_1: Bluetooth_1 {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&bt BT_SEL 0>;
            label = "Bluetooth_1";
        };

        Taskbar_2: Taskbar_2 {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings =
                <&macro_press>,
                <&kp LEFT_WIN>,
                <&macro_tap>,
                <&kp NUMBER_2>,
                <&macro_release>,
                <&kp LEFT_WIN>;

            label = "TASKBAR_2";
            wait-ms = <50>;
            tap-ms = <50>;
        };

        Taskbar_3: Taskbar_3 {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings =
                <&macro_press>,
                <&kp LEFT_WIN>,
                <&macro_tap>,
                <&kp NUMBER_3>,
                <&macro_release>,
                <&kp LEFT_WIN>;

            label = "TASKBAR_3";
            wait-ms = <50>;
            tap-ms = <50>;
        };

        Taskbar_4: Taskbar_4 {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings =
                <&macro_press>,
                <&kp LEFT_WIN>,
                <&macro_tap>,
                <&kp NUMBER_4>,
                <&macro_release>,
                <&kp LEFT_WIN>;

            label = "TASKBAR_4";
            wait-ms = <50>;
            tap-ms = <50>;
        };

        Taskbar_5: Taskbar_5 {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings =
                <&macro_press>,
                <&kp LEFT_WIN>,
                <&macro_tap>,
                <&kp N5>,
                <&macro_release>,
                <&kp LEFT_WIN>;

            label = "TASKBAR_5";
            wait-ms = <50>;
            tap-ms = <50>;
        };

        CtrlAltDel: CtrlAltDel {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings =
                <&macro_press>,
                <&kp LEFT_CONTROL>,
                <&macro_press>,
                <&kp LEFT_ALT>,
                <&macro_press>,
                <&kp DELETE>,
                <&macro_release>,
                <&kp LEFT_CONTROL>,
                <&macro_release>,
                <&kp LEFT_ALT>,
                <&macro_release>,
                <&kp DELETE>;

            label = "CTRLALTDEL";
        };

        Taskbar_6: Taskbar_6 {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings =
                <&macro_press>,
                <&kp LEFT_WIN>,
                <&macro_tap>,
                <&kp NUMBER_6>,
                <&macro_release>,
                <&kp LEFT_WIN>;

            label = "TASKBAR_6";
            wait-ms = <50>;
            tap-ms = <50>;
        };

        Taskbar_7: Taskbar_7 {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings =
                <&macro_press>,
                <&kp LEFT_WIN>,
                <&macro_tap>,
                <&kp N7>,
                <&macro_release>,
                <&kp LEFT_WIN>;

            label = "TASKBAR_7";
            wait-ms = <50>;
            tap-ms = <50>;
        };

        Taskbar_8: Taskbar_8 {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings =
                <&macro_press>,
                <&kp LEFT_WIN>,
                <&macro_tap>,
                <&kp N8>,
                <&macro_release>,
                <&kp LEFT_WIN>;

            label = "TASKBAR_8";
            wait-ms = <50>;
            tap-ms = <50>;
        };

        Taskbar_9: Taskbar_9 {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings =
                <&macro_press>,
                <&kp LEFT_WIN>,
                <&macro_tap>,
                <&kp NUMBER_9>,
                <&macro_release>,
                <&kp LEFT_WIN>;

            label = "TASKBAR_9";
            wait-ms = <50>;
            tap-ms = <50>;
        };

        Taskbar_10: Taskbar_10 {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings =
                <&macro_press>,
                <&kp LEFT_WIN>,
                <&macro_tap>,
                <&kp NUMBER_0>,
                <&macro_release>,
                <&kp LEFT_WIN>;

            label = "TASKBAR_10";
            wait-ms = <50>;
            tap-ms = <50>;
        };

        Taskbar_1: Taskbar_1 {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings =
                <&macro_press>,
                <&kp LEFT_WIN>,
                <&macro_tap>,
                <&kp NUMBER_1>,
                <&macro_release>,
                <&kp LEFT_WIN>;

            label = "TASKBAR_1";
            wait-ms = <50>;
            tap-ms = <50>;
        };

        Bluetooth_2: Bluetooth_2 {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&bt BT_SEL 1>;
            label = "BLUETOOTH_2";
        };

        Bluetooth_3: Bluetooth_3 {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&bt BT_SEL 2>;
            label = "BLUETOOTH_3";
        };

        NewWindow_macro: NewWindow_macro {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings =
                <&macro_press>,
                <&kp LEFT_WIN>,
                <&macro_tap>,
                <&kp E>,
                <&macro_release>,
                <&kp LEFT_WIN>;

            label = "NEWWINDOW_MACRO";
            wait-ms = <50>;
            tap-ms = <50>;
        };

        Switch_macro: Switch_macro {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings =
                <&macro_press>,
                <&kt LEFT_WIN>,
                <&macro_tap>,
                <&kp TAB>,
                <&macro_release>,
                <&kp LEFT_WIN>;

            label = "SWITCH_MACRO";
            wait-ms = <25>;
            tap-ms = <25>;
        };

        paint_macro: paint_macro {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings =
                <&macro_press>,
                <&kp LEFT_WIN>,
                <&macro_tap>,
                <&kp NUMBER_1>,
                <&macro_release>,
                <&kp LEFT_WIN>;

            label = "PAINT_MACRO";
            wait-ms = <50>;
            tap-ms = <50>;
        };

        Brackets_macro: Brackets_macro {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp LEFT_PARENTHESIS &kp RIGHT_PARENTHESIS &kp LEFT>;
            label = "BRACKETS_MACRO";
            wait-ms = <50>;
            tap-ms = <50>;
        };

        CB_History_macro: CB_History_macro {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings =
                <&macro_press>,
                <&kp LEFT_WIN>,
                <&macro_tap>,
                <&kp V>,
                <&macro_release>,
                <&kp LEFT_WIN>;

            label = "CB_History_macro";
            wait-ms = <1>;
            tap-ms = <1>;
        };

        MoveRight_macro: MoveRight_macro {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings =
                <&macro_press>,
                <&kp LEFT_WIN &kp LEFT_SHIFT>,
                <&macro_tap>,
                <&kp RIGHT>,
                <&macro_release>,
                <&kp LEFT_WIN &kp LEFT_SHIFT>;

            label = "MOVERIGHT_MACRO";
            wait-ms = <1>;
            tap-ms = <1>;
        };

        SelectLine_macro: SelectLine_macro {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp HOME &kp LS(END)>;
            label = "SELECTLINE_MACRO";
        };

        MoveLeft_macro: MoveLeft_macro {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings =
                <&macro_press>,
                <&kp LEFT_WIN &kp LEFT_SHIFT>,
                <&macro_tap>,
                <&kp LEFT>,
                <&macro_release>,
                <&kp LEFT_WIN &kp LEFT_SHIFT>;

            label = "MOVELEFT_MACRO";
            wait-ms = <1>;
            tap-ms = <1>;
        };

        TextExtractor_macro: TextExtractor_macro {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings =
                <&macro_press>,
                <&kp LEFT_WIN &kp LEFT_SHIFT>,
                <&macro_tap>,
                <&kp T>,
                <&macro_release>,
                <&kp LEFT_WIN &kp LEFT_SHIFT>;

            label = "TEXTEXTRACTOR_MACRO";
            wait-ms = <1>;
            tap-ms = <1>;
        };

        ACADE_SaveZoomClose: SaveZoomClose {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp S &kp V &kp RET>;
            label = "SAVEZOOMCLOSE";
        };

        ACADE_CloseNoSave: ACADE_close {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp C &kp C &kp RET>;
            label = "ACADE_CLOSE";
        };

        ACADE_edit: ACADE_edit {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp E &kp D &kp I &kp T &kp RET>;
            label = "ACADE_EDIT";
        };

        ACADE_Align: ACADE_Align {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp A &kp E &kp A &kp RET>;
            label = "ACADE_ALIGN";
        };

        ACADE_SaveNext: ACADE_SaveNext {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp N &kp N &kp RET>;
            label = "ACADE_SAVENEXT";
        };

        ACADE_SavePrevious: ACADE_SavePrevious {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp B &kp B &kp RET>;
            label = "ACADE_SAVEPREVIOUS";
        };

        ACADE_Wire: ACADE_Wire {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp A &kp E &kp W &kp RET>;
            label = "ACADE_WIRE";
        };

        ACADE_FlipWireNo: ACADE_FlipWireNo {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp A &kp E &kp F &kp L &kp W &kp RET>;
            label = "ACADE_FLIPWIRENO";
        };

        ACADE_Justify: ACADE_Justify {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp A &kp E &kp J &kp RET>;
            label = "ACADE_JUSTIFY";
        };

        ACADE_Surf: ACADE_Surf {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp A &kp E &kp S &kp RET>;
            label = "ACADE_SURF";
        };

        ACADE_TabEnter: ACADE_TabEnter {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings =
                <&macro_tap>,
                <&kp TAB>,
                <&macro_wait_time 50>,
                <&kp ENTER>;

            label = "ACADE_TABENTER";
        };

        ACADE_PAN: ACADE_PANS {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings =
                <&macro_tap>,
                <&kp P>,
                <&macro_wait_time 50>,
                <&kp ENTER>;

            label = "ACADE_PANS";
        };

        WinTab: WinTab {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings =
                <&macro_press>,
                <&kp LEFT_WIN>,
                <&macro_tap>,
                <&kp TAB>,
                <&macro_release>,
                <&kp LEFT_WIN>;

            label = "WINTAB";
            wait-ms = <50>;
            tap-ms = <50>;
        };
    };

    keymap {
        compatible = "zmk,keymap";

        default_layer {
            display-name = "Base";
            bindings = <
          &mt TAB Q         &kp W  &kp E       &kp R      &kp T  &kp P      &kp O            &kp I               &kp U             &kp Y
          &mt LEFT_SHIFT A  &kp S  &kp D       &kp F      &kp G  &kp SQT    &mt RIGHT_ALT L  &mt LEFT_CONTROL K  &mt LEFT_SHIFT J  &kp N
          &mt LCTRL Z       &kp X  &kp C       &kp V      &kp B  &kp SLASH  &kp PERIOD       &kp COMMA           &kp M             &kp N
                            &kp E  &kp ESCAPE  &kp ENTER  &mo 1             &kp I            &kp BACKSPACE       &kp SPACE         &mo 2
                            &kp M  &kp N       &kp O      &kp P             &kp Q            &kp R               &kp S             &kp T
                            &kp U  &kp V       &kp W      &kp X             &kp Y            &kp Z               &kp A             &kp B
            >;

            sensor-bindings = <&inc_dec_kp A B &inc_dec_kp DOWN UP &inc_dec_kp E F &inc_dec_kp LEFT RIGHT>;
        };

        layer_1 {
            bindings = <
          &kp PG_UP  &kp HOME  &kp UP    &kp END    &kp TAB    &kp RBKT   &kp N9  &kp N8  &kp N7  &kp LBKT
          &kp PG_DN  &kp LEFT  &kp DOWN  &kp RIGHT  &kp LC(X)  &kp SEMI   &kp N6  &kp N5  &kp N4  &kp EQUAL
          &kp LALT   &trans    &trans    &kp LG(V)  &kp LGUI   &kp GRAVE  &kp N3  &kp N2  &kp N1  &kp BSLH
                     &trans    &trans    &trans     &trans                &trans  &trans  &trans  &trans
                     &trans    &trans    &trans     &trans                &trans  &trans  &trans  &trans
                     &trans    &trans    &trans     &trans                &trans  &trans  &trans  &trans
            >;
        };

        layer_2 {
            bindings = <
          &Taskbar_1  &Taskbar_2   &Taskbar_3  &Taskbar_4  &trans  &trans  &trans  &trans  &trans  &trans
          &Taskbar_5  &Taskbar_6   &Taskbar_7  &Taskbar_8  &trans  &trans  &trans  &trans  &trans  &trans
          &Taskbar_9  &Taskbar_10  &trans      &trans      &trans  &trans  &trans  &trans  &trans  &trans
                      &trans       &trans      &trans      &trans          &trans  &trans  &trans  &trans
                      &trans       &trans      &trans      &trans          &trans  &trans  &trans  &trans
                      &trans       &trans      &trans      &trans          &trans  &trans  &trans  &trans
            >;
        };
    };
};
